# Telegram
TELEGRAM_TOKEN=your_telegram_bot_token
WEBHOOK_BASE_URL=https://your-domain.com

# AI Engine: "anthropic" | "openai"
AI_ENGINE=anthropic

# Anthropic / Claude
ANTHROPIC_API_KEY=your_anthropic_api_key
CLAUDE_MODEL=claude-sonnet-4-20250514

# OpenAI (also required for Whisper audio transcription)
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://medbot:medbot123@postgres:5432/medbot
POSTGRES_USER=medbot
POSTGRES_PASSWORD=medbot123
POSTGRES_DB=medbot

# Redis
REDIS_URL=redis://redis:6379/0

# ChromaDB
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# RAG embed model: small (~120MB, fast) | base | large (~1GB, best recall)
# Or any FastEmbed-supported model id.
EMBED_MODEL=small

# JWT
JWT_SECRET=change_this_to_a_random_secret
JWT_EXPIRE_HOURS=24

# App
APP_ENV=production
LOG_LEVEL=INFO

# Clinic info
CLINIC_NAME=Phòng khám Đa khoa MedBot
CLINIC_ADDRESS=123 Đường ABC, Quận 1, TP.HCM
CLINIC_PHONE=0901234567
CLINIC_HOURS=Thứ 2 - Thứ 7: 8:00 - 17:00
CLINIC_EMAIL=info@medbot.vn

# Admin dashboard
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password

# Session auto-close after inactivity (minutes, 0 = disabled)
SESSION_TIMEOUT_MINUTES=30

# Zalo OA (optional — leave empty to disable)
ZALO_APP_ID=
ZALO_APP_SECRET=
ZALO_OA_ACCESS_TOKEN=
ZALO_OA_REFRESH_TOKEN=
